---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout title="Privacy Policy" description="Privacy policy placeholder for Lotus Aesthetics & Wellness.">
  <Header />
  <main class="container">
    <section class="section">
      <div class="page-hero__inner">
        <p class="page-hero__eyebrow">Privacy Policy</p>
        <h1>Privacy Policy</h1>
        <p>
          This is a placeholder privacy policy page for the Lotus Aesthetics & Wellness demo. Replace it with the
          practice's final legal copy, consent language, and HIPAA-related website disclosures before launch.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
