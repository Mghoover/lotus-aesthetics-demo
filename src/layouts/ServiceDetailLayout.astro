---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getRelatedServices } from "../data/services";
import LocalServiceArea from "../components/LocalServiceArea.astro";
import { siteConfig } from "../config/site";
import type { ConditionDetail } from "../types/condition-detail";

interface Service {
  slug: string;
  title: string;
  heroTagline: string;
  conditions?: string[];
  intro: string[];
  sections: any[];
  cta: any;
  statusNote?: string;
  faq?: Array<{
    question: string;
    answer: string;
  }>;
}

const { service, relatedConditions = [] } = Astro.props as {
  service: Service;
  relatedConditions?: ConditionDetail[];
};
const ctaHref = service.cta.buttonHref ?? "/contact-us/";
const canonicalUrl = `${siteConfig.siteUrl}/services/${service.slug}`;
const pageTitle = service.title;
const ogTitle = `${service.title} | ${siteConfig.clinicName}`;
const relatedServices = getRelatedServices(service.slug, 4);
const medicalBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  name: siteConfig.clinicName,
  url: siteConfig.siteUrl,
  medicalSpecialty: siteConfig.seo.medicalSpecialty,
  areaServed: {
    "@type": "Place",
    name: siteConfig.seo.marketName,
  },
};
const medicalProcedureSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  name: service.title,
  procedureType: "TherapeuticProcedure",
  bodyLocation: "Human Body",
  provider: {
    "@type": "MedicalBusiness",
    name: siteConfig.clinicName,
  },
};
const faqSchema =
  service.faq && service.faq.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: service.faq.map((q) => ({
          "@type": "Question",
          name: q.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: q.answer,
          },
        })),
      }
    : null;
---

<BaseLayout title={pageTitle} description={service.heroTagline}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(medicalBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(medicalProcedureSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={service.heroTagline} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
  </Fragment>

  <Header />

  <main>
    <section class="section service-hero">
      <div class="container">
        <p class="service-label">Service Detail</p>
        <h1>{service.title}</h1>
        <p class="service-tagline">{service.heroTagline}</p>
        {service.statusNote && <p class="service-status-note">{service.statusNote}</p>}
      </div>
    </section>

    <section class="section">
      <div class="container service-content">
        <article class="card service-card-block">
          <h2>Overview</h2>
          {service.intro.map((paragraph) => <p>{paragraph}</p>)}
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container service-content">
        {service.sections.map((item) => (
          <article class="card service-card-block">
            <h2>{item.title}</h2>
            {item.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {item.bulletPoints && item.bulletPoints.length > 0 && (
              <ul>
                {item.bulletPoints.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            )}
            {item.faq && item.faq.length > 0 && (
              <div class="service-faq-list" aria-label={`${item.title} questions`}>
                {item.faq.map((entry) => (
                  <article class="service-faq-item">
                    <h3>{entry.question}</h3>
                    <p>{entry.answer}</p>
                  </article>
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </section>

    {service.faq && service.faq.length > 0 && (
      <section class="section">
        <div class="container service-content">
          <article class="card service-card-block">
            <h2>Frequently Asked Questions</h2>
            <div class="service-faq-list" aria-label={`${service.title} frequently asked questions`}>
              {service.faq.map((entry) => (
                <article class="service-faq-item">
                  <h3>{entry.question}</h3>
                  <p>{entry.answer}</p>
                </article>
              ))}
            </div>
          </article>
        </div>
      </section>
    )}

    {relatedConditions.length > 0 && (
      <section class="section related-conditions">
        <div class="container">
          <h2>Conditions That May Benefit</h2>
          <p>
            Many of our services are used to support patients experiencing specific
            musculoskeletal or neurological symptoms.
          </p>
          <div class="conditions-grid">
            {relatedConditions.slice(0, 5).map((condition) => (
              <a href={`/conditions/${condition.slug}`} class="condition-link">
                <h3>{condition.title}</h3>
                <p>{condition.heroTagline}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      <div class="container">
        <aside class="cta-banner service-cta" aria-label="Schedule Consultation">
          <div class="cta-content">
            <h2>{service.cta.title}</h2>
            <p>{service.cta.description}</p>
            <a href={ctaHref} class="btn btn-primary">{service.cta.buttonText}</a>
          </div>
        </aside>
      </div>
    </section>

    {relatedServices.length > 0 && (
      <section class="section">
        <div class="container service-content">
          <article class="card service-card-block related-services-block">
            <h2>Related Services</h2>
            <ul class="related-services-list">
              {relatedServices.map((item) => (
                <li>
                  <a href={`/services/${item.slug}`}>{item.title}</a>
                </li>
              ))}
            </ul>
          </article>
        </div>
      </section>
    )}
  </main>

  <LocalServiceArea />
  <Footer />
</BaseLayout>

<style>
  .service-hero {
    border-top: none;
    background:
      radial-gradient(circle at 15% 20%, rgba(107, 95, 211, 0.1), transparent 45%),
      radial-gradient(circle at 85% 10%, rgba(43, 182, 115, 0.1), transparent 42%),
      #f8f9fb;
  }

  .service-label {
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent-purple);
  }

  .service-hero h1 {
    margin-bottom: 10px;
    font-size: clamp(2rem, 3.2vw, 2.8rem);
  }

  .service-tagline {
    margin: 0;
    max-width: 760px;
    color: #374151;
    font-size: clamp(1.04rem, 2vw, 1.3rem);
  }

  .service-content {
    max-width: 860px;
  }

  .service-status-note {
    margin-top: 14px;
    margin-bottom: 0;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid #d8d3f3;
    background: rgba(107, 95, 211, 0.08);
    color: #312e81;
    font-size: 0.94rem;
    max-width: 760px;
  }

  .service-card-block {
    margin-bottom: 24px;
    padding: 28px;
  }

  .service-card-block:last-child {
    margin-bottom: 0;
  }

  .service-card-block h2 {
    margin-bottom: 14px;
  }

  .service-card-block p {
    margin: 0 0 12px;
    font-size: 1.03rem;
    line-height: 1.72;
  }

  .service-card-block p:last-child {
    margin-bottom: 0;
  }

  .service-card-block ul {
    margin: 10px 0 0;
    padding-left: 20px;
  }

  .service-card-block li {
    margin-bottom: 8px;
    line-height: 1.55;
  }

  .service-card-block li:last-child {
    margin-bottom: 0;
  }

  .service-faq-list {
    margin-top: 14px;
    display: grid;
    gap: 10px;
  }

  .service-faq-item {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: #f9fbff;
    padding: 14px;
  }

  .service-faq-item h3 {
    margin: 0 0 8px;
    font-size: 1.03rem;
  }

  .service-faq-item p {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.62;
  }

  .service-cta {
    margin-top: 0;
    width: 100%;
  }

  .related-conditions .container {
    max-width: 1100px;
  }

  .related-conditions h2 {
    margin-bottom: 8px;
  }

  .related-conditions p {
    margin: 0 0 18px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 820px;
  }

  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .condition-link {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #ffffff;
    padding: 18px;
    text-decoration: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .condition-link:hover {
    border-color: var(--accent-purple);
    box-shadow: 0 8px 24px rgba(107, 95, 211, 0.12);
    transform: translateY(-2px);
  }

  .condition-link h3 {
    margin: 0 0 8px;
    color: #111827;
    font-size: 1.08rem;
  }

  .condition-link p {
    margin: 0;
    color: var(--muted);
    line-height: 1.58;
    font-size: 0.95rem;
  }

  .related-services-block {
    margin-top: 0;
  }

  .related-services-list {
    margin: 6px 0 0;
    padding-left: 20px;
    display: grid;
    gap: 8px;
  }

  .related-services-list li {
    line-height: 1.55;
  }

  .related-services-list a {
    color: var(--accent-purple);
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .conditions-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .conditions-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
