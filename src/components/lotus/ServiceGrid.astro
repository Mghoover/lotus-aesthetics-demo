---
import SectionIntro from "./SectionIntro.astro";
import type { SectionIntro as SectionIntroType, ServiceCard } from "../../types/lotus";

const {
  intro,
  items,
  subdued = false,
} = Astro.props as {
  intro?: SectionIntroType;
  items: ServiceCard[];
  subdued?: boolean;
};
---
<section class:list={["section", subdued && "section-muted"]}>
  <div class="container">
    {intro && <SectionIntro {...intro} />}
    <div class="lotus-card-grid">
      {items.map((item) => (
        <article class="lotus-service-card">
          <div class="lotus-service-card__body">
            {item.eyebrow && <p class="lotus-service-card__eyebrow">{item.eyebrow}</p>}
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            {item.idealFor && <p class="lotus-service-card__ideal">{item.idealFor}</p>}
            {item.bullets && item.bullets.length > 0 && (
              <ul class="lotus-service-card__list">
                {item.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
          </div>
          <a class="text-link" href={item.href}>
            {item.linkLabel ?? "Learn more"}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
