---
const { eyebrow, title, description, align = "left" } = Astro.props;
---
<div class:list={["section-intro", align === "center" && "is-centered"]}>
  {eyebrow && <p class="section-intro__eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p class="section-intro__description">{description}</p>}
</div>
