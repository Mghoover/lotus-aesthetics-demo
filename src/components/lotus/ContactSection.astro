---
import SectionIntro from "./SectionIntro.astro";
import type { ContactCard, SectionIntro as SectionIntroType } from "../../types/lotus";
import { lotusContent } from "../../content/lotus";

const contactEmail = lotusContent.business.email;

const {
  cards,
  formIntro,
  mapIntro,
} = Astro.props as {
  cards: ContactCard[];
  formIntro: SectionIntroType;
  mapIntro: SectionIntroType;
};
---
<section class="section">
  <div class="container">
    <div class="lotus-contact-grid">
      {cards.map((card) => (
        <article class="lotus-contact-card">
          <h2>{card.title}</h2>
          <p>{card.body}</p>
          {card.href && card.linkLabel && (
            <a class="text-link" href={card.href}>
              {card.linkLabel}
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section section-muted">
  <div class="container">
    <div class="lotus-contact-layout">
      <div class="lotus-form-card">
        <SectionIntro {...formIntro} />
        <form class="lotus-contact-form" id="consultation-form" data-mailto-form>
          <label>
            Full Name
            <input name="name" type="text" placeholder="Your name" required />
          </label>
          <label>
            Email
            <input name="email" type="email" placeholder="you@example.com" required />
          </label>
          <label>
            Phone
            <input name="phone" type="tel" placeholder="(843) 555-5555" />
          </label>
          <label>
            Service Interest
            <select name="service">
              <option>Botox or filler consultation</option>
              <option>PRP facial rejuvenation</option>
              <option>Hair restoration</option>
              <option>IV hydration therapy</option>
              <option>Weight-loss support</option>
              <option>Same-day medical visit</option>
            </select>
          </label>
          <label>
            Message
            <textarea
              name="message"
              rows="5"
              placeholder="Tell us a little about what you would like to book."
            ></textarea>
          </label>
          <button type="submit">Request Appointment</button>
          <p class="lotus-contact-form__note">
            Demo wiring currently routes requests through your default email client. Connect this section to your live form or booking platform before launch.
          </p>
          <p class="lotus-contact-form__status" aria-live="polite"></p>
        </form>
      </div>

      <div class="lotus-map-card">
        <SectionIntro {...mapIntro} />
        <div class="lotus-map-placeholder">
          <img
            src="/images/lotus/map-placeholder.svg"
            alt="Map placeholder for Lotus Aesthetics & Wellness"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="lotus-map-card__details">
          <p>{lotusContent.business.addressLine}</p>
          <p>{lotusContent.business.cityStateZip}</p>
          <p>{lotusContent.business.hoursNote}</p>
          <a class="btn btn-secondary" href={lotusContent.business.directionsHref} target="_blank" rel="noreferrer">
            Open Directions
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ contactEmail }}>
  (() => {
    const form = document.querySelector("[data-mailto-form]");
    if (!form) return;

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      const status = form.querySelector(".lotus-contact-form__status");
      const formData = new FormData(form);
      const name = String(formData.get("name") || "").trim();
      const email = String(formData.get("email") || "").trim();
      const phone = String(formData.get("phone") || "").trim();
      const service = String(formData.get("service") || "").trim();
      const message = String(formData.get("message") || "").trim();
      const subject = encodeURIComponent(`Lotus booking request from ${name || "website visitor"}`);
      const body = encodeURIComponent(
        [
          `Name: ${name}`,
          `Email: ${email}`,
          `Phone: ${phone}`,
          `Service Interest: ${service}`,
          "",
          message,
        ].join("\n"),
      );

      window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
      if (status) {
        status.textContent = "Your email client should open with a pre-filled booking request.";
      }
    });
  })();
</script>
