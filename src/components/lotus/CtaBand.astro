---
import type { CtaBandData } from "../../types/lotus";

const { section } = Astro.props as { section: CtaBandData };
---
<section class="section">
  <div class="container">
    <div class="lotus-cta-band">
      <div>
        <p class="lotus-cta-band__eyebrow">Book With Lotus</p>
        <h2>{section.title}</h2>
        <p>{section.description}</p>
      </div>
      <div class="lotus-cta-band__actions">
        {section.ctas.map((cta) => (
          <a class:list={["btn", cta.variant === "secondary" ? "btn-secondary" : "btn-primary"]} href={cta.href}>
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
