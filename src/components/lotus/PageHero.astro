---
import type { PageHeroData } from "../../types/lotus";

const { hero } = Astro.props as { hero: PageHeroData };
---
<section class="page-hero">
  <div class="container">
    <div class="page-hero__inner">
      {hero.eyebrow && <p class="page-hero__eyebrow">{hero.eyebrow}</p>}
      <h1>{hero.title}</h1>
      <p>{hero.description}</p>
    </div>
  </div>
</section>
