---
import { siteConfig } from "../config/site";
---
<section class="section local-service-area">
  <div class="container">
    <p>{siteConfig.seo.serviceAreaSummary}</p>
  </div>
</section>

<style>
  .local-service-area {
    padding-top: 28px;
    padding-bottom: 28px;
    background: #f7f8fb;
  }

  .local-service-area p {
    margin: 0;
    text-align: center;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.65;
  }
</style>
